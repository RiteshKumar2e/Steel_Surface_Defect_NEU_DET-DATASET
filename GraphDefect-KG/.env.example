# GraphDefect-KG environment configuration (copy to .env and edit as needed)
# All values are optional; sensible defaults are used when unset.

# --- Server ---
HOST=127.0.0.1
PORT=8000
DEVICE=auto            # auto | cpu | cuda
MAX_UPLOAD_MB=10

# --- Dataset locations (auto-discovered if left unset) ---
# Point these at the NEU-DET dataset if it lives outside the repo.
# NEU_DET_IMAGES=../NEU-DET/IMAGES
# NEU_DET_ANNOTATIONS=../NEU-DET/ANNOTATIONS

# --- Preprocessing ---
IMAGE_SIZE=224
APPLY_CLAHE=1
PATCH_GRID=4           # NxN grid of patch nodes per image

# --- Graph construction ---
KNN_K=5
KNN_METRIC=cosine      # cosine | euclidean | combined

# --- Model ---
PRETRAINED=1           # 1 = load ImageNet weights for MobileNetV2
